# Vercel Environment Variables
NODE_ENV=production
VERCEL_ENV=production
VERCEL_URL=https://foundersconnect.co.in

PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/startuplanes
JWT_SECRET=replace-with-a-strong-random-secret
CLIENT_ORIGIN=http://localhost:5173
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Redis Configuration (Upstash for serverless)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# SMTP configuration for newsletters
# Do NOT commit real credentials. Copy these to a local .env and fill values.
# SMTP host (e.g. smtp.gmail.com)
SMTP_HOST=smtp.gmail.com
# SMTP port (587 for STARTTLS, 465 for SSL)
SMTP_PORT=587
# Use secure=true for port 465, false otherwise
SMTP_SECURE=false

# SMTP auth (preferred)
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password-or-app-password

# Alternative env names supported by backend (if you prefer these):
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-smtp-password-or-app-password

# From address used when sending newsletters
NEWSLETTER_FROM_EMAIL=Founders Connect <no-reply@foundersconnect.app>

# GROQ AI
# Official chat-completions endpoint (OpenAI-compatible syntax, served by Groq)
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=git 
GROQ_MODEL=llama-3.1-8b-instant
